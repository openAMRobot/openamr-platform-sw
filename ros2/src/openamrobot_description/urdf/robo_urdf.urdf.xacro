<?xml version="1.0" encoding="utf-8"?>
<!--
  OpenAMRobot differential-drive robot description.

  Link/joint geometry and STL meshes originate from a SolidWorks-exported URDF
  (sw_urdf_exporter, Stephen Brawner) by Niraj Dhakal (the upstream URDF author),
  later packaged by Raj Indulkar in openamrobot-simulation. See top-level
  NOTICE.md for the full attribution chain.

  Modifications applied in this revision (openamrobot-docking contribution):
    - added a base_footprint root link + base_joint (Nav2 TF convention)
    - symmetrised left/right wheel inertials (off-diagonals set to 0 and the
      two wheels made identical) — fixes the "robot circles when commanded
      straight" failure caused by SolidWorks-exported asymmetries
    - added camera_link and camera_rgb_optical_frame for AprilTag detection
    - lidar range adjusted to 0.15-12 m (see gazebo_control.xacro)
    - cylinder collisions on drive wheels with radius 0.10 m (reconciled
      with the DiffDrive plugin wheel_radius — see gazebo_control.xacro)
-->
<robot
  name="openamrobot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    base_footprint: ground-projection of base_link, Nav2 convention.
    base_joint lifts base_link 0.053467 m so the drive-wheel centres sit at
    z = wheel_radius = 0.10 m above the ground when base_footprint is at z=0.
  -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 0.053467" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <link
    name="base_link">
