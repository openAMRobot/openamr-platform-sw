  <!--
    Drive wheels.

    Inertials made symmetric: off-diagonal terms zeroed and ixx = iyy = izz
    forced to the same average so left and right behave identically. The
    SolidWorks-exported per-wheel inertials had tiny (1e-8) off-diagonal
    asymmetries that made the robot curve when commanded straight in Gazebo.
  -->
  <link
    name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1.06112497715273" />
      <inertia
        ixx="0.003398197" ixy="0" ixz="0"
        iyy="0.006426349" iyz="0"
        izz="0.003397389" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://openamrobot_description/meshes/visual/left_wheel_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <!-- 0.11 cylinder vs DiffDrive wheel_radius=0.10 gives ~1 cm of
             penetration into the ground plane, which ODE's contact solver
             uses to apply traction. Without that overlap the wheels merely
             touch the floor and the robot does not move. -->
        <cylinder radius="0.11" length="0.046"/>
      </geometry>
    </collision>
  </link>
  <joint
    name="left_wheel_joint"
    type="continuous">
    <origin
      xyz="4.7743E-05 0.20375 0.046533"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="left_wheel_link" />
    <axis
      xyz="0 1 0" />
    <dynamics damping="0.001" friction="0.001" />
  </joint>
  <link
    name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1.06112497715273" />
      <inertia
        ixx="0.003398197" ixy="0" ixz="0"
        iyy="0.006426349" iyz="0"
        izz="0.003397389" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
