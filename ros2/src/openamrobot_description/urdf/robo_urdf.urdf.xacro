    <axis
      xyz="0 0 0" />
  </joint>

  <!--
    Camera links.

    camera_link is the physical camera frame (X forward, Y left, Z up).
    camera_rgb_optical_frame is its image-coordinate counterpart (X right,
    Y down, Z forward) — the convention apriltag_ros::solvePnP requires when
    computing the AprilTag pose. The rotation rpy="-1.5708 0 -1.5708" applied
    to the optical joint is the standard −π/2, 0, −π/2 mapping.
  -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.35 0 0.22" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <link name="camera_rgb_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
    <parent link="camera_link"/>
    <child link="camera_rgb_optical_frame"/>
  </joint>

  <xacro:include filename="gazebo_control.xacro" />


</robot>
